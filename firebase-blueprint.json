
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "discordUsername": { "type": "string" },
        "telegramUsername": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A script or resource for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "framework": { "type": "string", "enum": ["QBCore", "ESX", "Standalone"] },
        "category": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "previewImageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "price", "framework", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase record for a script.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "delivered"] },
        "createdAt": { "type": "number" }
      },
      "required": ["customerId", "productId", "amount", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Script products available in the store."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase orders."
    }
  }
}
